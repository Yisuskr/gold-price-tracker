# Copy this file to .env and fill in your values

# App configuration
APP_HOST=127.0.0.1
APP_PORT=8050
DEBUG=True

# Data refresh interval in seconds (price chart)
REFRESH_INTERVAL=60

# Google Gemini API key (get one free at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# How often the AI analysis refreshes (seconds). Default 1800 = 30 min.
# Free tier allows 1500 requests/day, so don't set this below 60.
AI_REFRESH_INTERVAL=1800

# Minimum confidence (0.0-1.0) to display BULLISH/BEARISH instead of NEUTRAL
AI_CONFIDENCE_THRESHOLD=0.4
